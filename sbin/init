#!/bin/bash

# 手动填写需要执行的测试脚本文件名；会分别在 /mnt/glibc 与 /mnt/musl 下执行。
TEST_CODES=(
    "basic_testcode.sh"
)

TEST_ROOTS=(
    "/mnt/glibc"
    "/mnt/musl"
)

AUTO_TEST_DELAY=5

manual_shell() {
    echo
    echo "[init] auto test interrupted, entering login shell"
    exec /bin/bash --login
}

countdown_before_auto_test() {
    echo "[init] auto test starts in ${AUTO_TEST_DELAY}s; press any key to enter shell"
    while [ "${AUTO_TEST_DELAY}" -gt 0 ]; do
        printf "\r[init] starting in %s..." "${AUTO_TEST_DELAY}"
        if read -r -s -n 1 -t 1 _key; then
            echo
            manual_shell
        fi
        AUTO_TEST_DELAY=$((AUTO_TEST_DELAY - 1))
    done
    echo
}

run_one_test() {
    local test_root="$1"
    local test_name="$2"
    local test_path="${test_root}/${test_name}"

    if [ ! -f "${test_path}" ]; then
        echo "[init] skip missing test: ${test_path}"
        return 0
    fi

    echo "[init] running test: ${test_path}"
    cd "${test_root}" || {
        echo "[init] failed to enter test root: ${test_root}"
        return 0
    }

    # 测试脚本依赖当前目录中的 busybox、basic 等相对路径资源。
    if [ -x "${test_path}" ]; then
        "./${test_name}"
    else
        /bin/bash "./${test_name}"
    fi
    local status=$?
    echo "[init] test exited: ${test_path}, status=${status}"
    return 0
}

countdown_before_auto_test

if [ "${#TEST_CODES[@]}" -eq 0 ]; then
    # TODO: 目前测试点文件名由手动列表提供，暂未实现自动遍历 *_testcode.sh。
    echo "[init] no test codes configured"
else
    for test_name in "${TEST_CODES[@]}"; do
        for test_root in "${TEST_ROOTS[@]}"; do
            run_one_test "${test_root}" "${test_name}"
        done
    done
fi

echo "[init] auto test finished, exiting pid 1"
exit 0
