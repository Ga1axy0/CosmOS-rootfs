#!/bin/sh

if [ $# -eq 0 ]; then
    echo "usage: ldd FILE..." >&2
    exit 1
fi

for f in "$@"; do
    if [ ! -e "$f" ]; then
        echo "ldd: $f: No such file or directory" >&2
        continue
    fi

    if grep -aq "/lib/ld-musl-riscv64.so.1" "$f" 2>/dev/null; then
        /lib/ld-musl-riscv64.so.1 --list "$f"
    elif grep -aq "/lib/ld-linux-riscv64-lp64d.so.1" "$f" 2>/dev/null; then
        /lib/ld-linux-riscv64-lp64d.so.1 --list "$f"
    else
        echo "$f: not a dynamic executable"
    fi
done
