#!/bin/bash
set -e

# Available testcode names:
# basic
# busybox
# cyclictest
# iozone
# iperf
# libcbench
# libctest
# lmbench
# ltp
# lua
# netperf
# unixbench
#
# Example:
# AUTO_RUN_PATTERN='(basic|busybox|ltp)_testcode\.sh$'
# AUTO_RUN_ORDER='basic busybox cyclictest iozone iperf libcbench libctest lmbench lua netperf unixbench ltp'

tree=${LTP_TREE:-both}
pattern=${AUTO_RUN_PATTERN:-'.*_testcode\.sh$'}
order=${AUTO_RUN_ORDER:-'basic busybox cyclictest iozone iperf libcbench libctest lmbench lua netperf unixbench ltp'}

enter_manual_shell() {
    echo
    echo "[ltp-auto-run] auto run cancelled, entering manual shell"
    exec /bin/bash --login
}

enable_interrupt_shell() {
    trap 'enter_manual_shell' INT
}

countdown_or_shell() {
    local secs=${AUTO_RUN_DELAY:-10}

    echo "[ltp-auto-run] press Ctrl-C within ${secs}s to cancel auto run"

    while [ "$secs" -gt 0 ]; do
        printf '\r[ltp-auto-run] starting in %2ds... ' "$secs"
        sleep 1
        secs=$((secs - 1))
    done

    printf '\r[ltp-auto-run] starting now...     \n'
}

pick_bases() {
    case "$tree" in
        musl) printf '%s\n' /mnt/musl ;;
        glibc) printf '%s\n' /mnt/glibc ;;
        both) printf '%s\n' /mnt/musl /mnt/glibc ;;
        *)
            echo "[ltp-auto-run] invalid LTP_TREE=$tree" >&2
            exit 2
            ;;
    esac
}

# 按脚本短名补齐实际测试脚本文件名。
normalize_script_name() {
    local name=$1

    case "$name" in
        *_testcode.sh) printf '%s\n' "$name" ;;
        *) printf '%s_testcode.sh\n' "$name" ;;
    esac
}

# 判断脚本文件名是否匹配当前筛选规则。
script_selected() {
    local script
    script=$(normalize_script_name "$1")
    printf '%s\n' "$script" | grep -E "$pattern" >/dev/null
}

# 打印按用户指定顺序筛选后的脚本列表。
list_ordered_scripts() {
    local item
    local script

    echo "[ltp-auto-run] ordered scripts:"
    for item in $order; do
        script=$(normalize_script_name "$item")
        if script_selected "$script"; then
            echo "  $script"
        fi
    done
}

# 在指定 libc 测试树下运行一个脚本；缺失时跳过。
run_one_script() {
    local base=$1
    local script=$2
    local path="$base/$script"

    [ -f "$path" ] || return 0
    echo "[ltp-auto-run] running $path"
    (
        cd "$base"
        if [ "$script" = "ltp_testcode.sh" ]; then
            case "$base" in
                /mnt/musl) exec /bin/bash /root/ltp-run-musl ;;
                /mnt/glibc) exec /bin/bash /root/ltp-run-glibc ;;
            esac
        fi
        /bin/bash "$script"
    )
}

# 按脚本顺序执行测试，同名脚本固定先 musl 后 glibc。
run_ordered_scripts() {
    local item
    local script
    local base

    for item in $order; do
        script=$(normalize_script_name "$item")
        if ! script_selected "$script"; then
            continue
        fi
        for base in $(pick_bases); do
            run_one_script "$base" "$script"
        done
    done
}

enable_interrupt_shell
countdown_or_shell
echo "[ltp-auto-run] tree=$tree pattern=$pattern order=$order"
list_ordered_scripts
run_ordered_scripts
trap - INT
echo "[ltp-auto-run] done"
